// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  MANAGER
  SALES
  ACCOUNTS
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tasks         Task[]
  notes         Note[]
  notifications Notification[]
  auditLogs     AuditLog[]
  activityLogs  ActivityLog[]
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  phone       String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leads       Lead[]
  bookings    Booking[]
  notes       Note[]
  documents   Document[]
  testimonials Testimonial[]
}

model Lead {
  id            String      @id @default(uuid())
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  source        String?
  status        LeadStatus  @default(NEW)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  followUps     FollowUp[]
}

model FollowUp {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
}

model Destination {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())

  packages    TourPackage[]
}

model TourPackage {
  id            String    @id @default(uuid())
  name          String
  categoryId    String
  category      PackageCategory @relation(fields: [categoryId], references: [id])
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id])
  highlights    String?
  inclusions    String?
  exclusions    String?
  terms         String?
  basePrice     Decimal   @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pricing       PackagePricing[]
  itineraries   Itinerary[]
  bookings      Booking[]
  reviews       Review[]
}

model PackageCategory {
  id        String        @id @default(uuid())
  name      String        @unique
  packages  TourPackage[]
}

model PackagePricing {
  id          String      @id @default(uuid())
  packageId   String
  package     TourPackage @relation(fields: [packageId], references: [id])
  seasonName  String
  startDate   DateTime
  endDate     DateTime
  price       Decimal     @db.Decimal(10, 2)
}

model Booking {
  id            String        @id @default(uuid())
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  packageId     String
  package       TourPackage   @relation(fields: [packageId], references: [id])
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  totalAmount   Decimal       @db.Decimal(10, 2)
  bookingDate   DateTime      @default(now())
  tourStartDate DateTime
  tourEndDate   DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payments      Payment[]
  vouchers      Voucher[]
  invoices      Invoice[]
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String
  booking       Booking       @relation(fields: [bookingId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime      @default(now())
  paymentMethod String
  receiptNumber String?       @unique
}

model Hotel {
  id          String    @id @default(uuid())
  name        String
  categoryId  String
  category    HotelCategory @relation(fields: [categoryId], references: [id])
  address     String?
  phone       String?
  email       String?
  createdAt   DateTime  @default(now())

  rooms       HotelRoom[]
}

model HotelCategory {
  id      String   @id @default(uuid())
  name    String   @unique
  hotels  Hotel[]
}

model HotelRoom {
  id          String   @id @default(uuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id])
  roomType    String
  basePrice   Decimal  @db.Decimal(10, 2)

  pricing     HotelPricing[]
}

model HotelPricing {
  id          String    @id @default(uuid())
  roomId      String
  room        HotelRoom @relation(fields: [roomId], references: [id])
  seasonName  String
  price       Decimal   @db.Decimal(10, 2)
}

model Vehicle {
  id            String   @id @default(uuid())
  model         String
  registration  String   @unique
  capacity      Int
  ownerSupplier String?
  baseRate      Decimal  @db.Decimal(10, 2)
}

model Driver {
  id          String   @id @default(uuid())
  name        String
  phone       String
  license     String   @unique
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  type        String // Hotel, Transport, etc.
  contactInfo String?
}

model Expense {
  id          String   @id @default(uuid())
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  description String?
}

model Income {
  id          String   @id @default(uuid())
  source      String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  description String?
}

model Invoice {
  id            String   @id @default(uuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  invoiceNumber String   @unique
  amount        Decimal  @db.Decimal(10, 2)
  taxAmount     Decimal  @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
}

model Voucher {
  id            String   @id @default(uuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  type          String // Hotel, Cab, Driver
  details       String?
  createdAt     DateTime @default(now())
}

model Quotation {
  id            String   @id @default(uuid())
  customerName  String
  customerEmail String
  details       Json
  totalAmount   Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
}

model Itinerary {
  id            String      @id @default(uuid())
  packageId     String
  package       TourPackage @relation(fields: [packageId], references: [id])
  dayNumber     Int
  title         String
  description   String?
  activities    String?
  meals         String?
}

model Task {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Note {
  id          String    @id @default(uuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  content     String
  createdAt   DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Document {
  id          String    @id @default(uuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  name        String
  url         String
  type        String
  createdAt   DateTime  @default(now())
}

model Gallery {
  id        String   @id @default(uuid())
  title     String?
  url       String
  category  String?
  createdAt DateTime @default(now())
}

model Review {
  id          String      @id @default(uuid())
  packageId   String
  package     TourPackage @relation(fields: [packageId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime    @default(now())
}

model Testimonial {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  content     String
  createdAt   DateTime  @default(now())
}

model CompanySetting {
  id          String @id @default("1")
  name        String
  logo        String?
  gstNumber   String?
  panNumber   String?
  address     String?
  phone       String?
  email       String?
  bankDetails String?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  activity  String
  createdAt DateTime @default(now())
}
