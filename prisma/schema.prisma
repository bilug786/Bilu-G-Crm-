generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  leads         Lead[]
  enquiries     Enquiry[]
  bookings      Booking[]
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  email         String?
  phone         String
  address       String?
  city          String?
  state         String?
  country       String?   @default("India")
  pincode       String?
  gstNumber     String?
  leads         Lead[]
  enquiries     Enquiry[]
  bookings      Booking[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

model Lead {
  id            String      @id @default(cuid())
  title         String
  description   String?
  status        LeadStatus  @default(NEW)
  source        String?
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  assignedToId  String?
  assignedTo    User?       @relation(fields: [assignedToId], references: [id])
  enquiries     Enquiry[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum EnquiryStatus {
  OPEN
  QUOTED
  CONFIRMED
  CANCELLED
}

model Enquiry {
  id            String        @id @default(cuid())
  leadId        String?
  lead          Lead?         @relation(fields: [leadId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  assignedToId  String?
  assignedTo    User?         @relation(fields: [assignedToId], references: [id])
  destination   String
  startDate     DateTime
  endDate       DateTime
  adults        Int           @default(0)
  children      Int           @default(0)
  infants       Int           @default(0)
  budget        Float?
  status        EnquiryStatus @default(OPEN)
  quotations    Quotation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Quotation {
  id            String      @id @default(cuid())
  enquiryId     String
  enquiry       Enquiry     @relation(fields: [enquiryId], references: [id])
  version       Int         @default(1)
  totalAmount   Float
  taxAmount     Float       @default(0)
  grandTotal    Float
  itinerary     Json?       // Stores the itinerary details
  status        String      @default("DRAFT")
  bookings      Booking[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Booking {
  id            String      @id @default(cuid())
  quotationId   String?
  quotation     Quotation?  @relation(fields: [quotationId], references: [id])
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        String      @default("CONFIRMED")
  totalAmount   Float
  paidAmount    Float       @default(0)
  itinerary     Json?
  vouchers      Voucher[]
  invoices      Invoice[]
  payments      Payment[]
  expenses      Expense[]
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Voucher {
  id            String      @id @default(cuid())
  bookingId     String
  booking       Booking     @relation(fields: [bookingId], references: [id])
  type          String      // HOTEL, TRANSPORT, etc.
  details       Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Invoice {
  id            String      @id @default(cuid())
  bookingId     String
  booking       Booking     @relation(fields: [bookingId], references: [id])
  invoiceNumber String      @unique
  amount        Float
  taxAmount     Float
  grandTotal    Float
  gstDetails    Json?
  status        String      @default("UNPAID")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Payment {
  id            String      @id @default(cuid())
  bookingId     String
  booking       Booking     @relation(fields: [bookingId], references: [id])
  amount        Float
  method        String
  transactionId String?
  date          DateTime    @default(now())
  notes         String?
  createdAt     DateTime    @default(now())
}

model Expense {
  id            String      @id @default(cuid())
  bookingId     String?
  booking       Booking?    @relation(fields: [bookingId], references: [id])
  category      String
  amount        Float
  date          DateTime    @default(now())
  supplierId    String?
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])
  description   String?
  createdAt     DateTime    @default(now())
}

model Hotel {
  id            String      @id @default(cuid())
  name          String
  address       String?
  city          String
  state         String?
  country       String      @default("India")
  rating        Int?
  contactPerson String?
  email         String?
  phone         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transport {
  id            String      @id @default(cuid())
  type          String      // Car, Bus, Flight, etc.
  provider      String
  contactNumber String?
  email         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Supplier {
  id            String      @id @default(cuid())
  name          String
  type          String      // HOTEL, TRANSPORT, AGENT, etc.
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  gstNumber     String?
  expenses      Expense[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
